---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const faqEntry = await getEntry("pages", "faq");

if (!faqEntry) {
    throw new Error("Conteúdo da página FAQ não encontrado em src/content/pages/faq.md.");
}

const { Content } = await faqEntry.render();
---

<Layout title="FAQ - Conselho dos Cidadãos" description="Perguntas frequentes sobre o Conselho de Cidadãos do Brasil em Pequim.">
    <div class="max-w-4xl mx-auto px-3 py-8 sm:px-5">
        <header class="internal-page-header">
            <h1 class="internal-page-title">{faqEntry.data.title}</h1>
            {faqEntry.data.subtitle && <p class="internal-page-subtitle">{faqEntry.data.subtitle}</p>}
        </header>

        <section class="markdown-content">
            <Content />
        </section>
    </div>
</Layout>
