---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} - Projetos`}>
    <div class="max-w-4xl mx-auto px-3 py-8 sm:px-5">
        <h1 class="internal-page-title mb-4">{entry.data.title}</h1>
        {entry.data.cover && <img src={entry.data.cover} alt={entry.data.title} class="w-full h-96 object-cover rounded-lg mb-8 shadow-lg" />}
        <div class="markdown-content max-w-none">
            <Content />
        </div>
    </div>
</Layout>
