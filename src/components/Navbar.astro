---
import ThemeToggle from "./ThemeToggle.astro";
import SocialLinks from "./SocialLinks.astro";
import { branding, primaryNavLinks } from "../config/site-links";
---

<nav class="site-navbar">
    <div class="max-w-7xl mx-auto px-3 sm:px-5 lg:px-6">
        <div class="flex h-14 items-center">
            <div class="flex min-w-0 flex-1 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <a
                        href="/"
                        class="navbar-logo-link flex items-center"
                        aria-label={branding.logoAlt}
                        title={branding.logoTitle ?? "Conselho dos Cidadãos Brasileiros de Beijing"}
                    >
                        <img
                            src={branding.logoPath ?? "/icons/conselho-top-logo-full.png"}
                            alt={branding.logoAlt}
                            title={branding.logoTitle ?? "Conselho dos Cidadãos Brasileiros de Beijing"}
                            class="h-14 w-52 object-contain dark:hidden"
                        />
                        <img
                            src={branding.logoPathDark ?? "/icons/conselho-top-logo-full-dark.png"}
                            alt={branding.logoAlt}
                            title={branding.logoTitle ?? "Conselho dos Cidadãos Brasileiros de Beijing"}
                            class="hidden  w-52 object-contain dark:block"
                        />
                    </a>
                </div>
            </div>

            <div class="hidden sm:flex items-center justify-center gap-6 px-4 transform translate-x-6">
                {
                    primaryNavLinks.map((link) => (
                        <a
                            href={link.href}
                            target={link.external ? "_blank" : "_self"}
                            rel={link.external ? "noopener noreferrer" : undefined}
                            class="nav-primary-link inline-flex items-center px-1 pt-1 border-b-2 text-sm font-semibold"
                        >
                            {link.name}
                        </a>
                    ))
                }
            </div>

            <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
                <div class="navbar-desktop-tools hidden md:flex items-center gap-4">
                    <SocialLinks class="flex items-center gap-4" popoverAlign="right" />
                    <ThemeToggle class="navbar-theme-toggle" />
                </div>
                <div class="-mr-2 flex items-center sm:hidden ml-2">
                    <button
                        type="button"
                        aria-label="Abrir menu principal"
                        class="mobile-menu-button site-menu-toggle"
                        aria-controls="mobile-menu"
                        aria-expanded="false"
                    >
                        <span class="sr-only">Abrir menu principal</span>
                        <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                        <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="site-navbar-accent" aria-hidden="true"></div>

    <div class="site-mobile-menu sm:hidden" id="mobile-menu" aria-hidden="true">
        <div class="pt-2 pb-3 space-y-1">
            {
                primaryNavLinks.map((link) => (
                    <a
                        href={link.href}
                        target={link.external ? "_blank" : "_self"}
                        rel={link.external ? "noopener noreferrer" : undefined}
                        class="nav-mobile-link block pl-3 pr-4 py-2 border-l-4 text-base font-medium"
                    >
                        {link.name}
                    </a>
                ))
            }
        </div>
        <div class="navbar-mobile-social px-3 py-3">
            <div class="flex items-center justify-between gap-4">
                <SocialLinks class="flex items-center gap-4" popoverAlign="left" />
                <ThemeToggle class="navbar-theme-toggle" />
            </div>
        </div>
    </div>
</nav>

<script>
    const btn = document.querySelector("button.mobile-menu-button");
    const menu = document.querySelector("#mobile-menu");

    if (btn instanceof HTMLButtonElement && menu instanceof HTMLElement) {
        let openScrollY = 0;
        let isMenuSettling = false;
        let lastScrollIntentAt = 0;
        const SCROLL_INTENT_WINDOW_MS = 450;

        const markScrollIntent = () => {
            lastScrollIntentAt = performance.now();
        };

        const closeMobileMenu = () => {
            if (!menu.classList.contains("is-open")) {
                return;
            }

            menu.classList.remove("is-open");
            menu.setAttribute("aria-hidden", "true");
            btn.setAttribute("aria-expanded", "false");
        };

        const openMobileMenu = () => {
            isMenuSettling = true;
            openScrollY = window.scrollY;
            menu.classList.add("is-open");
            menu.setAttribute("aria-hidden", "false");
            btn.setAttribute("aria-expanded", "true");

            requestAnimationFrame(() => {
                openScrollY = window.scrollY;
                isMenuSettling = false;
            });
        };

        const handleScrollClose = () => {
            if (!menu.classList.contains("is-open")) {
                return;
            }

            if (isMenuSettling) {
                return;
            }

            if (performance.now() - lastScrollIntentAt > SCROLL_INTENT_WINDOW_MS) {
                return;
            }

            if (Math.abs(window.scrollY - openScrollY) < 2) {
                return;
            }

            closeMobileMenu();
        };

        btn.addEventListener("click", () => {
            const expanded = btn.getAttribute("aria-expanded") === "true";

            if (expanded) {
                closeMobileMenu();
                return;
            }

            openMobileMenu();
        });

        window.addEventListener("scroll", handleScrollClose, { passive: true });
        window.addEventListener("touchmove", markScrollIntent, { passive: true });
        window.addEventListener("wheel", markScrollIntent, { passive: true });
    }
</script>
